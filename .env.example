# Defaults to sqljs (SQLite WASM) in-memory — no setup, boots in Bolt.new.
# For a durable database, switch with one env (no code change):
#   DB_DIALECT=sqlite   DATABASE_URL=./app.db                 # local Node (npm i better-sqlite3)
#   DB_DIALECT=postgres DATABASE_URL=postgres://user:pass@host/db
ORM_SEED_ON_BOOT=1
